# ============================================
# Node.js 依赖
# ============================================
node_modules/
*/node_modules/
package-lock.json
*/package-lock.json

# ============================================
# 构建产物
# ============================================
dist/
*/dist/
dist-ssr/
*.local
.vercel/

# ============================================
# 日志文件
# ============================================
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================
# 操作系统文件
# ============================================
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
*~

# ============================================
# IDE 编辑器配置
# ============================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# ============================================
# 环境变量（保护敏感信息）
# ============================================
.env
.env.local
.env.*.local

# ============================================
# Preprocessing 预处理文件（本地文件，不上传）
# ============================================
# 原始视频素材（通常很大，不上传）
preprocessing/source-videos/
# 提取的帧（临时文件）
preprocessing/frames/
# 但保留 output/analysis-results.json（需要上传）
!preprocessing/output/

# ============================================
# 视频文件处理规则
# ============================================
# ⚠️ 重要：client/public/videos/ 下的视频要上传！
# 这里不忽略 client/public/videos/

# 但忽略超大视频文件（如果你有备份视频）
**/backup-videos/
**/*.avi
**/*.mov
**/*.mkv

# ============================================
# 其他
# ============================================
# 测试覆盖率
coverage/

# 临时文件
*.tmp
*.temp

# 压缩包
*.zip
*.rar
*.7z